{
  "name": "lummaca-code-editor",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "service:install": "sudo cp ./lummaca-editor.service /etc/systemd/system/lummaca-editor.service && sudo systemctl daemon-reload && sudo systemctl enable lummaca-editor.service",
    "service:start": "sudo systemctl start lummaca-editor.service",
    "service:stop": "sudo systemctl stop lummaca-editor.service",
    "service:restart": "sudo systemctl restart lummaca-editor.service",
    "service:status": "sudo systemctl status lummaca-editor.service",
    "service:logs": "sudo journalctl -u lummaca-editor.service -f",
    "service:logs:tail": "sudo journalctl -u lummaca-editor.service -n 200 --no-pager",
    "deploy": "yarn build && sudo systemctl restart lummaca-editor.service && sudo systemctl status lummaca-editor.service --no-pager",
    "deploy:firebase": "firebase deploy --only hosting"
  },
  "dependencies": {
    "@types/node": "^18.15.5",
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "monaco-editor": "^0.36.1",
    "monaco-themes": "^0.4.4",
    "typescript": "^4.9.3",
    "vite": "^4.2.0",
    "vite-plugin-monaco-editor": "^1.1.0",
    "vite-plugin-static-copy": "^1.0.1"
  }
}